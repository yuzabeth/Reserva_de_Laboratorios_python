    <string notr="true">QTableWidget {
    background-color: #F5F5F5; /* Color de fondo de la tabla */
    border: 1px solid #F0F3F4; /* Borde de la tabla */
    border-radius: 4px; /* Esquinas redondeadas de la tabla */
    padding: 4px; /* Espaciado interno de la tabla */
    gridline-color: #F0F3F4; /* Color de las líneas de la cuadrícula */
}

QTableWidget::item {
    padding: 4px; /* Espaciado interno de las celdas */
}

QTableWidget::item:hover {
    background-color: #ECF0F1; /* Color de fondo de la celda al pasar el ratón */
}

QTableWidget::item:selected {
    background-color: #3498DB; /* Color de fondo de la celda seleccionada */
