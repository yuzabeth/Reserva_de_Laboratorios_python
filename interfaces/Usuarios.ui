  <widget class="QComboBox" name="comboBoxDocEst">
   <property name="geometry">
    <rect>
     <x>630</x>
     <y>100</y>
     <width>131</width>
     <height>31</height>
    </rect>
   </property>
   <property name="font">
    <font>
     <weight>75</weight>
     <bold>true</bold>
    </font>
   </property>
   <property name="styleSheet">
    <string notr="true">/* Estilo base del QComboBox */
QComboBox {
    border: 1px solid #B0B0B0; /* Borde del combobox */
    border-radius: 5px; /* Esquinas redondeadas */
    padding: 1px 18px 1px 3px; /* Espaciado interno */
    min-width: 6em; /* Ancho mínimo del combobox */
    color: #333333; /* Color del texto */
    background-color: #E5E7E9; /* Color de fondo */
    selection-background-color: #D5DBDB; /* Color de fondo cuando está seleccionado */
}

/* Estilo del área editable del QComboBox */
QComboBox:editable {
    background: #FFFFFF; /* Fondo del área editable si es un combobox editable */
}

/* Estilo del botón desplegable */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: right center;
    width: 20px; /* Ancho del botón desplegable */
    border-left: 1px solid #B0B0B0; /* Borde izquierdo del botón desplegable */
}


/* Estilo al pasar el ratón sobre el QComboBox */
QComboBox:hover {
    border: 1px solid #7D7D7D; /* Borde cuando el mouse pasa sobre el combobox */
}

/* Estilo al pasar el ratón sobre el botón desplegable */
QComboBox::drop-down:hover {
    background: #BFC9CA; /* Fondo del botón desplegable cuando el mouse pasa sobre él */
}

/* Estilo al seleccionar una opción en el QComboBox */
QComboBox::item:selected {
    background-color: #A9DEF9; /* Color de fondo cuando está seleccionado */
}

/* Estilo del texto en las opciones del QComboBox */
QComboBox::item {
    padding: 4px; /* Espaciado interno de las opciones */
}

/* Estilo de la flecha cuando el QComboBox está desplegado */
QComboBox:on {
    padding-top: 3px;
    padding-left: 4px;
    background: #EBEBEB; /* Fondo cuando el combobox está desplegado */
}


</string>
   </property>
