   <property name="styleSheet">
    <string notr="true">/* Estilo base del botón */
QPushButton {
    background-color: #E5E7E9; /* Color de fondo */
    color: black; /* Color del texto */
    border: 2px solid #E5E7E9; /* Borde del botón */
    border-radius: 4px; /* Esquinas redondeadas */
    padding: 8px 16px; /* Espaciado interno */
}

/* Estilo al pasar el ratón sobre el botón */
QPushButton:hover {
    background-color: #D5DBDB; /* Nuevo color de fondo al pasar el ratón */
    border: 2px solid #CCD1D1; /* Nuevo borde al pasar el ratón */
    color: black; /* Nuevo color del texto al pasar el ratón */
}

/* Estilo al hacer clic en el botón */
QPushButton:pressed {
    background-color: #BFC9CA; /* Nuevo color de fondo al hacer clic */
    border: 2px solid #BFC9CA; /* Nuevo borde al hacer clic */
    color: black; /* Nuevo color del texto al hacer clic */
}
